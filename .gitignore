# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# ── Compiled output ──────────────────────────────────────────
dist/
tmp/
out-tsc/
*.tsbuildinfo
.expo/
.expo-shared/

# ── Dependencies ─────────────────────────────────────────────
node_modules/

# ── Environment & secrets ────────────────────────────────────
.env
.env.*
!.env.example
*credentials*.json
*-credentials.json
firebase-credentials.json
service-account*.json
google-credentials*.json
*-key.json

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── IDEs & editors ───────────────────────────────────────────
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.sublime-workspace
.project
.classpath
.c9/
*.launch
.settings/

# ── OS files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Replit specific ──────────────────────────────────────────
.replit
replit.nix
.cache/
.local/
.upm/

# ── Misc ─────────────────────────────────────────────────────
.sass-cache/
/connect.lock
/coverage/
/typings/
.cursor/
.github/instructions/
